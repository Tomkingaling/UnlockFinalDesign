{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/buttons/**",
              "components/data/**",
              "components/disclosure/**",
              "components/effects/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/surfaces/**",
              "components/text/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Aeonik|Inter|Noto Serif JP))/i]",
        "message": "Font not provided by the design system. Available: Aeonik, Inter, Noto Serif JP."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:q|a|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: q, a."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArcButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onClick|variant|type|full|style|key|ref|className|style|children)$/]",
        "message": "<ArcButton> doesn't accept that prop. Declared props: children, onClick, variant, type, full, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArcButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline)$/]",
        "message": "<ArcButton> variant must be one of 'primary' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArcButton'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<ArcButton> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|red|neutral)$/]",
        "message": "<Badge> tone must be one of 'green' | 'amber' | 'red' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hover|highlighted|radius|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, hover, highlighted, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:m|l)$/]",
        "message": "<Card> radius must be one of 'm' | 'l'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparisonRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|values|key|ref|className|style|children)$/]",
        "message": "<ComparisonRow> doesn't accept that prop. Declared props: label, values."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|change|key|ref|className|style|children)$/]",
        "message": "<TickerItem> doesn't accept that prop. Declared props: label, value, change."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hero|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, hero, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|desc|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, desc."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|as|type|placeholder|options|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, as, type, placeholder, options, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|select)$/]",
        "message": "<Field> as must be one of 'input' | 'select'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:tagline|links|onNavigate|showDisclaimer|disclaimer|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: tagline, links, onNavigate, showDisclaimer, disclaimer."
      },
      {
        "selector": "JSXOpeningElement[name.name='GridPulse'] > JSXAttribute > JSXIdentifier[name!=/^(?:pattern|key|ref|className|style|children)$/]",
        "message": "<GridPulse> doesn't accept that prop. Declared props: pattern."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCallout'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|onDismiss|key|ref|className|style|children)$/]",
        "message": "<InsightCallout> doesn't accept that prop. Declared props: label, children, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeadCaptureInline'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|placeholder|cta|note|onSubmit|key|ref|className|style|children)$/]",
        "message": "<LeadCaptureInline> doesn't accept that prop. Declared props: heading, placeholder, cta, note, onSubmit."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onNavigate|onDemo|onLogin|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: items, active, onNavigate, onDemo, onLogin."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingTier'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|period|desc|features|cta|highlighted|onCta|key|ref|className|style|children)$/]",
        "message": "<PricingTier> doesn't accept that prop. Declared props: name, price, period, desc, features, cta, highlighted, onCta."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|role|initials|key|ref|className|style|children)$/]",
        "message": "<PullQuote> doesn't accept that prop. Declared props: quote, name, role, initials."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lead|align|size|divider|actions|maxWidth|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, title, lead, align, size, divider, actions, maxWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:hero|display|section|sectionSm)$/]",
        "message": "<SectionHeader> size must be one of 'hero' | 'display' | 'section' | 'sectionSm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|size|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: children, as, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3)$/]",
        "message": "<SectionHeading> as must be one of 'h1' | 'h2' | 'h3'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:hero|display|section|sectionSm)$/]",
        "message": "<SectionHeading> size must be one of 'hero' | 'display' | 'section' | 'sectionSm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|style|key|ref|className|style|children)$/]",
        "message": "<StatBlock> doesn't accept that prop. Declared props: value, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|content|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: label, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|bio|initials|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: name, role, bio, initials."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|variant|title|message|duration|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: open, variant, title, message, duration, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:success|info|warning|error)$/]",
        "message": "<Toast> variant must be one of 'success' | 'info' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UnlockLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:height|style|key|ref|className|style|children)$/]",
        "message": "<UnlockLogo> doesn't accept that prop. Declared props: height, style."
      }
    ]
  },
